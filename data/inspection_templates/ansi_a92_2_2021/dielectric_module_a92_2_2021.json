{
  "format": "AF_INSPECTION_TEMPLATE",
  "format_version": 1,
  "template": {
    "template_key": "ansi_a92_2_periodic_dielectric",
    "name": "ANSI A92.2-2021 Periodic - Insulating Components & Dielectric Testing",
    "status": "PUBLISHED",
    "standard": {
      "code": "ANSI/SAIA A92.2",
      "revision": "2021"
    },
    "intent": {
      "inspection_kind": "PERIODIC",
      "domain": "AERIAL_DEVICE",
      "tags": ["dielectric", "insulating", "compliance"]
    },
    "applicability": {
      "asset_types": ["EQUIPMENT", "VEHICLE"],
      "required_capabilities": ["INSULATING_SYSTEM"],
      "optional_capabilities": ["BARE_HAND_WORK_UNIT", "DC_BARE_HAND_WORK_UNIT"],
      "notes": "Applicability rules may be refined by asset subtype later."
    },
    "policy": {
      "evidence_rules": {
        "photo_required_if_severity_at_least": "SERVICE_REQUIRED",
        "notes_required_on_fail": true,
        "block_finalize_if_required_steps_incomplete": true
      },
      "hashing": {
        "canonicalization": "JSON_CANONICAL_SORT_KEYS_UTF8_NO_WHITESPACE",
        "hash_algorithm": "SHA256"
      }
    }
  },

  "enums": {
    "severity": ["SAFE", "MINOR", "SERVICE_REQUIRED", "UNSAFE_OUT_OF_SERVICE"],
    "step_status": ["PASS", "FAIL", "NOT_PERFORMED", "NOT_APPLICABLE"],
    "test_type": ["AC", "DC"],
    "unit_category": ["A", "B", "C", "D", "E"],
    "inspection_context": ["BEFORE_USE", "PERIODIC", "POST_REPAIR", "MAJOR_REPAIR"]
  },

  "schemas": {
    "measurement_sets": [
      {
        "measurement_set_id": "dielectric_core_measurements",
        "title": "Dielectric Test Measurements",
        "fields": [
          {
            "field_id": "rated_line_voltage_kv",
            "label": "Rated line voltage (kV)",
            "type": "NUMBER",
            "required": true,
            "precision": 2,
            "min": 0.1
          },
          {
            "field_id": "applied_test_voltage_kv",
            "label": "Applied test voltage (kV)",
            "type": "NUMBER",
            "required": true,
            "precision": 2,
            "min": 0.1
          },
          {
            "field_id": "test_duration_seconds",
            "label": "Test duration (seconds)",
            "type": "NUMBER",
            "required": true,
            "precision": 0,
            "min": 1
          },
          {
            "field_id": "final_leakage_current_microamps",
            "label": "Final leakage current (µA)",
            "type": "NUMBER",
            "required": true,
            "precision": 2,
            "min": 0
          }
        ]
      }
    ],

    "defect_schema": {
      "defect_id_format": "UUID",
      "fields": [
        { "field_id": "title", "type": "TEXT", "required": true },
        { "field_id": "severity", "type": "ENUM", "enum_ref": "severity", "required": true },
        { "field_id": "standard_reference", "type": "TEXT", "required": false },
        { "field_id": "location", "type": "TEXT", "required": false },
        { "field_id": "notes", "type": "TEXTAREA", "required": false },
        { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
      ]
    }
  },

  "rules": [
    {
      "rule_id": "dielectric_duration_must_be_3_minutes",
      "title": "Dielectric test duration must be 3 minutes (180 seconds)",
      "standard_reference": "ANSI A92.2-2021 5.4.3.x",
      "when": { "step_key": "dielectric_test_execute" },
      "assert": {
        "type": "NUMERIC_EQUALS",
        "left": { "path": "measurements.test_duration_seconds" },
        "right": 180
      },
      "on_fail": {
        "severity": "UNSAFE_OUT_OF_SERVICE",
        "defect_title": "Dielectric test duration not compliant (must be 3 minutes)"
      }
    },
    {
      "rule_id": "ac_leakage_limit_cat_ab",
      "title": "AC leakage limit: Category A/B = 1 µA per kV",
      "standard_reference": "ANSI A92.2-2021 Table 2 / 5.4.3",
      "when": {
        "all": [
          { "path": "inputs.test_type", "equals": "AC" },
          { "path": "inputs.unit_category", "in": ["A", "B"] }
        ]
      },
      "assert": {
        "type": "NUMERIC_LTE",
        "left": { "path": "measurements.final_leakage_current_microamps" },
        "right_formula": "inputs.rated_line_voltage_kv * 1.0"
      },
      "on_fail": {
        "severity": "UNSAFE_OUT_OF_SERVICE",
        "defect_title": "AC leakage exceeds allowable limit (Category A/B)"
      }
    },
    {
      "rule_id": "dc_leakage_limit_cat_ab",
      "title": "DC leakage limit: Category A/B = 0.5 µA per kV",
      "standard_reference": "ANSI A92.2-2021 Table 2 / 5.4.3",
      "when": {
        "all": [
          { "path": "inputs.test_type", "equals": "DC" },
          { "path": "inputs.unit_category", "in": ["A", "B"] }
        ]
      },
      "assert": {
        "type": "NUMERIC_LTE",
        "left": { "path": "measurements.final_leakage_current_microamps" },
        "right_formula": "inputs.rated_line_voltage_kv * 0.5"
      },
      "on_fail": {
        "severity": "UNSAFE_OUT_OF_SERVICE",
        "defect_title": "DC leakage exceeds allowable limit (Category A/B)"
      }
    },
    {
      "rule_id": "leakage_limit_cat_cde",
      "title": "Leakage limit: Category C/D/E = 30 µA per kV (AC or DC)",
      "standard_reference": "ANSI A92.2-2021 Table 2 / 5.4.3",
      "when": { "path": "inputs.unit_category", "in": ["C", "D", "E"] },
      "assert": {
        "type": "NUMERIC_LTE",
        "left": { "path": "measurements.final_leakage_current_microamps" },
        "right_formula": "inputs.rated_line_voltage_kv * 30.0"
      },
      "on_fail": {
        "severity": "UNSAFE_OUT_OF_SERVICE",
        "defect_title": "Leakage exceeds allowable limit (Category C/D/E)"
      }
    }
  ],

  "procedure": {
    "inputs": [
      { "input_id": "inspection_context", "type": "ENUM", "enum_ref": "inspection_context", "required": true },
      { "input_id": "unit_category", "type": "ENUM", "enum_ref": "unit_category", "required": true },
      { "input_id": "test_type", "type": "ENUM", "enum_ref": "test_type", "required": true }
    ],

    "steps": [
      {
        "step_key": "insulating_visual_inspection",
        "type": "VISUAL_CHECK",
        "title": "Inspect insulating components & systems",
        "standard_reference": "ANSI A92.2-2021 8.2.4(16)",
        "required": true,
        "fields": [
          { "field_id": "cleanliness", "type": "ENUM", "values": ["CLEAN", "DIRTY", "CONTAMINATED"], "required": true },
          { "field_id": "visible_damage_present", "type": "BOOLEAN", "required": true },
          { "field_id": "contamination_types", "type": "CHOICE_MULTI", "choices": ["DIRT", "OIL", "MOISTURE", "SALT", "OTHER"], "required": false },
          { "field_id": "notes", "type": "TEXTAREA", "required": false },
          { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
        ],
        "auto_defect_on": [
          {
            "when": { "any": [
              { "path": "fields.cleanliness", "in": ["DIRTY", "CONTAMINATED"] },
              { "path": "fields.visible_damage_present", "equals": true }
            ]},
            "defect": {
              "title": "Insulating system condition may be compromised (cleanliness/damage)",
              "severity": "SERVICE_REQUIRED",
              "standard_reference": "ANSI A92.2-2021 8.2.4(16)"
            }
          }
        ]
      },

      {
        "step_key": "dielectric_test_setup",
        "type": "SETUP",
        "title": "Dielectric test setup",
        "standard_reference": "ANSI A92.2-2021 5.4.3.1, 5.4.3.2",
        "required": true,
        "fields": [
          { "field_id": "insulated_from_ground_paths", "type": "BOOLEAN", "required": true },
          { "field_id": "shielded_coax_used", "type": "BOOLEAN", "required": true },
          { "field_id": "boom_position_figure", "type": "ENUM", "values": ["FIG_1","FIG_2","FIG_2A","FIG_3","FIG_4"], "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ],
        "blocking_fail": true
      },

      {
        "step_key": "dielectric_test_equipment",
        "type": "SETUP",
        "title": "Select test equipment and verify calibration",
        "standard_reference": "ANSI A92.2-2021 5.6.3 (documentation) + internal policy",
        "required": true,
        "fields": [
          { "field_id": "test_equipment_asset_id", "type": "ASSET_REFERENCE", "asset_role": "TEST_EQUIPMENT", "required": true },
          { "field_id": "calibration_due_date", "type": "DATE", "required": true },
          { "field_id": "calibration_valid", "type": "BOOLEAN", "required": true }
        ],
        "blocking_fail": true
      },

      {
        "step_key": "dielectric_test_execute",
        "type": "MEASUREMENT",
        "title": "Perform dielectric test (AC or DC)",
        "standard_reference": "ANSI A92.2-2021 5.4.3 / Table 2",
        "required": true,
        "measurement_set_ref": "dielectric_core_measurements",
        "fields": [
          { "field_id": "test_notes", "type": "TEXTAREA", "required": false },
          { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
        ],
        "evaluations": [
          { "apply_rule_ids": ["dielectric_duration_must_be_3_minutes","ac_leakage_limit_cat_ab","dc_leakage_limit_cat_ab","leakage_limit_cat_cde"] }
        ]
      },

      {
        "step_key": "upper_controls_high_resistance",
        "type": "MEASUREMENT",
        "title": "Test upper controls with high electrical resistance components",
        "standard_reference": "ANSI A92.2-2021 5.4.3.6",
        "required": false,
        "visibility_conditions": {
          "any": [
            { "path": "asset.capabilities", "contains": "HIGH_RESISTANCE_UPPER_CONTROLS" }
          ]
        },
        "fields": [
          { "field_id": "performed", "type": "BOOLEAN", "required": true },
          { "field_id": "ac_test_kv", "type": "NUMBER", "required": false },
          { "field_id": "ac_current_microamps", "type": "NUMBER", "required": false },
          { "field_id": "dc_test_kv", "type": "NUMBER", "required": false },
          { "field_id": "dc_current_microamps", "type": "NUMBER", "required": false },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ]
      },

      {
        "step_key": "dielectric_documentation",
        "type": "DOCUMENTATION",
        "title": "Record dielectric test documentation",
        "standard_reference": "ANSI A92.2-2021 5.6.3",
        "required": true,
        "fields": [
          { "field_id": "testing_entity_name", "type": "TEXT", "required": true },
          { "field_id": "device_make", "type": "TEXT", "required": true },
          { "field_id": "device_model", "type": "TEXT", "required": true },
          { "field_id": "device_serial_number", "type": "TEXT", "required": true },
          { "field_id": "unit_category", "type": "ENUM", "enum_ref": "unit_category", "required": true },
          { "field_id": "rated_line_voltage_kv", "type": "NUMBER", "required": true },
          { "field_id": "test_context", "type": "ENUM", "enum_ref": "inspection_context", "required": true },
          { "field_id": "test_type", "type": "ENUM", "enum_ref": "test_type", "required": true },
          { "field_id": "applied_test_voltage_kv", "type": "NUMBER", "required": true },
          { "field_id": "final_leakage_current_microamps", "type": "NUMBER", "required": true },
          { "field_id": "date_of_test", "type": "DATE", "required": true }
        ]
      }
    ]
  }
}
