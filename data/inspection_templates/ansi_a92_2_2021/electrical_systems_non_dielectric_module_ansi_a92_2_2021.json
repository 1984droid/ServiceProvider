{
  "format": "AF_INSPECTION_TEMPLATE",
  "format_version": 1,
  "template": {
    "template_key": "ansi_a92_2_2021_electrical_non_dielectric_module",
    "name": "ANSI A92.2-2021 – Electrical Systems & Components (Non-Dielectric) (Module)",
    "status": "DRAFT",
    "standard": { "code": "ANSI/SAIA A92.2", "revision": "2021" },
    "intent": {
      "inspection_kind": "PERIODIC",
      "domain": "AERIAL_DEVICE",
      "tags": ["electrical", "controls", "wiring", "connectors", "grounding", "non_dielectric"]
    },
    "policy": {
      "evidence_rules": {
        "photo_required_if_severity_at_least": "SERVICE_REQUIRED",
        "notes_required_on_fail": true,
        "block_finalize_if_required_steps_incomplete": true
      },
      "hashing": {
        "canonicalization": "JSON_CANONICAL_SORT_KEYS_UTF8_NO_WHITESPACE",
        "hash_algorithm": "SHA256"
      }
    }
  },

  "enums": {
    "severity": ["SAFE", "MINOR", "SERVICE_REQUIRED", "UNSAFE_OUT_OF_SERVICE"],
    "step_status": ["PASS", "FAIL", "NOT_PERFORMED", "NOT_APPLICABLE"],
    "inspection_context": ["PERIODIC", "POST_REPAIR", "MAJOR_REPAIR", "POST_EVENT"],
    "component_group": [
      "WIRING_HARNESS",
      "CONNECTORS_TERMINALS",
      "CONTROL_PANELS",
      "SWITCHES_RELAYS",
      "SAFETY_DEVICES",
      "GROUNDING_BONDING",
      "SENSORS_LIMITS",
      "POWER_DISTRIBUTION",
      "OTHER"
    ],
    "symptom_type": [
      "FRAYED_DAMAGED_WIRE",
      "EXPOSED_CONDUCTOR",
      "LOOSE_CONNECTION",
      "CORROSION",
      "MISSING_COMPONENT",
      "BROKEN_HOUSING",
      "DIRT_DEBRIS_MOISTURE",
      "OVERHEATING_DISCOLORATION",
      "MELTED_INSULATION",
      "BURNT_ODOR",
      "IMPROPER_LABELING",
      "UNINTENTIONAL_ACTUATION_RISK",
      "FAILS_RETURN_TO_NEUTRAL",
      "ENABLING_DEVICE_FAIL",
      "VISIBILITY_ISSUE",
      "SAFETY_DEVICE_FAIL",
      "GROUNDING_FAULT",
      "OTHER"
    ],
    "action_taken": ["NONE", "CLEANED", "TIGHTENED", "REPAIRED", "REPLACED", "REMOVED_FROM_SERVICE", "DEFERRED"]
  },

  "schemas": {
    "measurement_sets": [
      {
        "measurement_set_id": "electrical_performance_measurements_optional",
        "title": "Electrical Performance Measurements (Optional, OEM-based)",
        "fields": [
          { "field_id": "performed", "type": "BOOLEAN", "required": true },
          { "field_id": "oem_spec_reference", "type": "TEXT", "required": false },
          { "field_id": "within_oem_spec", "type": "BOOLEAN", "required": true },
          { "field_id": "measured_value_1", "type": "NUMBER", "required": false, "precision": 2 },
          { "field_id": "measured_unit_1", "type": "TEXT", "required": false },
          { "field_id": "measured_value_2", "type": "NUMBER", "required": false, "precision": 2 },
          { "field_id": "measured_unit_2", "type": "TEXT", "required": false },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ]
      }
    ],

    "defect_schema": {
      "defect_id_format": "UUID",
      "fields": [
        { "field_id": "title", "type": "TEXT", "required": true },
        { "field_id": "severity", "type": "ENUM", "enum_ref": "severity", "required": true },
        { "field_id": "standard_reference", "type": "TEXT", "required": false },
        { "field_id": "component_group", "type": "ENUM", "enum_ref": "component_group", "required": true },
        { "field_id": "component_identifier", "type": "TEXT", "required": false },
        { "field_id": "symptoms", "type": "CHOICE_MULTI", "enum_ref": "symptom_type", "required": true },
        {
          "field_id": "location_zone",
          "type": "ENUM",
          "values": ["BASE", "TURRET", "LOWER_BOOM", "UPPER_BOOM", "JIB", "PLATFORM", "OUTRIGGERS", "CHASSIS", "OTHER"],
          "required": false
        },
        { "field_id": "location_detail", "type": "TEXT", "required": false },
        { "field_id": "inspection_context", "type": "ENUM", "enum_ref": "inspection_context", "required": false },
        { "field_id": "action_taken", "type": "ENUM", "enum_ref": "action_taken", "required": true },
        { "field_id": "notes", "type": "TEXTAREA", "required": false },
        { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
      ]
    }
  },

  "procedure": {
    "inputs": [
      { "input_id": "inspection_context", "type": "ENUM", "enum_ref": "inspection_context", "required": true },
      { "input_id": "asset_capabilities", "type": "ASSET_CAPABILITIES", "required": false }
    ],

    "steps": [
      {
        "step_key": "electrical_preparation",
        "type": "SETUP",
        "title": "Preparation for electrical systems inspection (non-dielectric)",
        "standard_reference": "ANSI A92.2-2021 8.2.4(11)",
        "required": true,
        "fields": [
          { "field_id": "worksite_safe", "type": "BOOLEAN", "required": true },
          { "field_id": "device_setup_complete", "type": "BOOLEAN", "required": true },
          { "field_id": "manufacturer_manual_reviewed", "type": "BOOLEAN", "required": true },
          { "field_id": "lockout_tagout_followed_if_required", "type": "BOOLEAN", "required": false },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ],
        "blocking_fail": true
      },

      {
        "step_key": "electrical_visual_inspection",
        "type": "DEFECT_CAPTURE",
        "title": "Visual inspection: wiring, connectors, panels, relays, contamination, overheating",
        "standard_reference": "ANSI A92.2-2021 8.2.3(1), 8.2.4(11)",
        "required": true,
        "defect_schema_ref": "defect_schema",
        "ui": {
          "mode": "ADD_DEFECT_ITEMS",
          "guidance": [
            "Inspect wiring for fraying, damage, exposed conductors.",
            "Inspect connectors/terminals for corrosion, looseness, missing parts.",
            "Inspect control panels for wear, damage, contamination/moisture.",
            "Look for overheating (discoloration, melted insulation, burnt odor)."
          ]
        },
        "fields": [
          {
            "field_id": "no_defects_found",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "If true, you must have zero defects recorded for this step."
          },
          { "field_id": "notes", "type": "TEXTAREA", "required": false },
          { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
        ],
        "validations": [
          {
            "validation_id": "no_defects_true_requires_zero_defects",
            "type": "CONSISTENCY",
            "rule": "IF fields.no_defects_found == true THEN defect_count == 0"
          }
        ]
      },

      {
        "step_key": "electrical_functional_testing",
        "type": "FUNCTIONAL_TEST",
        "title": "Functional testing: switches, relays, control panels, safety devices",
        "standard_reference": "ANSI A92.2-2021 8.2.4(11), 4.3",
        "required": true,
        "fields": [
          { "field_id": "tested_switches_relays", "type": "BOOLEAN", "required": true },
          { "field_id": "tested_control_panels", "type": "BOOLEAN", "required": true },
          { "field_id": "responds_correctly_to_inputs", "type": "BOOLEAN", "required": true },
          { "field_id": "tested_visual_audible_safety_devices", "type": "BOOLEAN", "required": false },
          {
            "field_id": "anomalies_observed",
            "type": "CHOICE_MULTI",
            "choices": ["INTERMITTENT", "NO_RESPONSE", "DELAYED_RESPONSE", "ERRATIC", "OTHER"],
            "required": false
          },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ],
        "auto_defect_on": [
          {
            "when": { "path": "fields.responds_correctly_to_inputs", "equals": false },
            "defect": {
              "title": "Electrical system does not respond correctly to control inputs",
              "severity": "UNSAFE_OUT_OF_SERVICE",
              "standard_reference": "ANSI A92.2-2021 8.2.4(11) / 4.3"
            }
          }
        ]
      },

      {
        "step_key": "control_systems_requirements",
        "type": "VISUAL_CHECK",
        "title": "Control systems: identification, protection, return-to-neutral, enabling devices",
        "standard_reference": "ANSI A92.2-2021 4.3 (incl. 4.3.1.1 / 4.3.1.2)",
        "required": true,
        "fields": [
          { "field_id": "controls_clearly_identified", "type": "BOOLEAN", "required": true },
          { "field_id": "controls_protected_from_damage_unintentional_actuation", "type": "BOOLEAN", "required": true },
          { "field_id": "controls_return_to_neutral", "type": "BOOLEAN", "required": true },
          { "field_id": "visibility_at_control_positions_ok", "type": "BOOLEAN", "required": false },
          { "field_id": "enabling_unlocking_devices_operate_correctly", "type": "BOOLEAN", "required": false },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ],
        "auto_defect_on": [
          {
            "when": {
              "any": [
                { "path": "fields.controls_clearly_identified", "equals": false },
                { "path": "fields.controls_protected_from_damage_unintentional_actuation", "equals": false },
                { "path": "fields.controls_return_to_neutral", "equals": false }
              ]
            },
            "defect": {
              "title": "Control system requirement not satisfied (ID/protection/neutral return)",
              "severity": "UNSAFE_OUT_OF_SERVICE",
              "standard_reference": "ANSI A92.2-2021 4.3"
            }
          }
        ]
      },

      {
        "step_key": "grounding_systems_inspection",
        "type": "DEFECT_CAPTURE",
        "title": "Inspect grounding/bonding systems (non-dielectric)",
        "standard_reference": "ANSI A92.2-2021 5.2.5",
        "required": true,
        "defect_schema_ref": "defect_schema",
        "ui": {
          "mode": "ADD_DEFECT_ITEMS",
          "guidance": [
            "Verify grounding connections are intact and free from corrosion.",
            "Check bonding/ground straps for wear/damage and secure attachment.",
            "Record any evidence of poor grounding, damage, or corrosion."
          ]
        }
      },

      {
        "step_key": "electrical_performance_optional",
        "type": "MEASUREMENT",
        "title": "Electrical performance verification (optional, OEM-based)",
        "standard_reference": "ANSI A92.2-2021 6.4",
        "required": false,
        "measurement_set_ref": "electrical_performance_measurements_optional",
        "fields": [
          {
            "field_id": "performance_dimension",
            "type": "TEXT",
            "required": true,
            "help_text": "Examples: voltage drop, continuity, resistance, battery charging voltage, alternator output, etc."
          }
        ],
        "auto_defect_on": [
          {
            "when": {
              "all": [
                { "path": "measurements.performed", "equals": true },
                { "path": "measurements.within_oem_spec", "equals": false }
              ]
            },
            "defect": {
              "title": "Electrical performance not within OEM specification",
              "severity": "SERVICE_REQUIRED",
              "standard_reference": "ANSI A92.2-2021 6.4 / 8.2.4(11)"
            }
          }
        ]
      },

      {
        "step_key": "electrical_post_repair_testing",
        "type": "FUNCTIONAL_TEST",
        "title": "Post-repair electrical functional verification",
        "standard_reference": "ANSI A92.2-2021 8.2.4(16)(c)",
        "required": false,
        "visibility_conditions": {
          "any": [
            { "path": "inspection_context", "equals": "POST_REPAIR" },
            { "path": "inspection_context", "equals": "MAJOR_REPAIR" },
            { "path": "inspection_context", "equals": "POST_EVENT" }
          ]
        },
        "fields": [
          { "field_id": "performed", "type": "BOOLEAN", "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ]
      },

      {
        "step_key": "electrical_modifications_reference",
        "type": "INSTRUCTION",
        "title": "Reference: Modifications require manufacturer permission",
        "standard_reference": "ANSI A92.2-2021 8.5",
        "required": false,
        "fields": [
          {
            "field_id": "note",
            "type": "RICH_TEXT",
            "required": false,
            "default": "Modifications to electrical systems/components require prior written permission from the manufacturer; if unavailable, approval by equivalent entity after engineering analysis."
          }
        ]
      },

      {
        "step_key": "electrical_documentation",
        "type": "DOCUMENTATION",
        "title": "Electrical systems inspection documentation (non-dielectric)",
        "standard_reference": "ANSI A92.2-2021 8.3.2",
        "required": true,
        "fields": [
          { "field_id": "inspection_date", "type": "DATE", "required": true },
          { "field_id": "performed_by_person", "type": "TEXT", "required": true },
          { "field_id": "systems_inspected_summary", "type": "TEXTAREA", "required": true },
          { "field_id": "findings_and_actions_summary", "type": "TEXTAREA", "required": false },
          { "field_id": "placard_applied", "type": "BOOLEAN", "required": true }
        ]
      }
    ]
  }
}
