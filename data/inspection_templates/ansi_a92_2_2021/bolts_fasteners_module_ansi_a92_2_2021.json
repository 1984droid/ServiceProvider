{
  "format": "AF_INSPECTION_TEMPLATE",
  "format_version": 1,
  "template": {
    "template_key": "ansi_a92_2_2021_bolts_fasteners_module",
    "name": "ANSI A92.2-2021 – Bolts & Fasteners (Module)",
    "status": "DRAFT",
    "standard": { "code": "ANSI/SAIA A92.2", "revision": "2021" },
    "intent": {
      "inspection_kind": "PERIODIC",
      "domain": "AERIAL_DEVICE",
      "tags": ["bolts", "fasteners", "torque", "locking", "structural_integrity"]
    },
    "policy": {
      "evidence_rules": {
        "photo_required_if_severity_at_least": "SERVICE_REQUIRED",
        "notes_required_on_fail": true,
        "block_finalize_if_required_steps_incomplete": true
      },
      "hashing": {
        "canonicalization": "JSON_CANONICAL_SORT_KEYS_UTF8_NO_WHITESPACE",
        "hash_algorithm": "SHA256"
      }
    }
  },

  "enums": {
    "severity": ["SAFE", "MINOR", "SERVICE_REQUIRED", "UNSAFE_OUT_OF_SERVICE"],
    "inspection_context": ["PERIODIC", "POST_REPAIR", "MAJOR_REPAIR", "POST_EVENT"],
    "fastener_role": [
      "STRUCTURAL",
      "LOAD_BEARING",
      "SAFETY_CRITICAL",
      "GENERAL",
      "OTHER"
    ],
    "symptom_type": [
      "CRACK",
      "CORROSION",
      "DEFORMATION",
      "LOOSE",
      "MISSING",
      "OVER_TORQUED",
      "UNDER_TORQUED",
      "STRIPPED_THREADS",
      "ROUNDED_HEAD",
      "IMPROPER_INSTALLATION",
      "LOCKING_DEVICE_MISSING",
      "LOCKING_DEVICE_FAILED",
      "MISALIGNMENT",
      "OTHER"
    ],
    "action_taken": ["NONE", "TIGHTENED", "REPLACED", "REPAIRED", "REMOVED_FROM_SERVICE", "DEFERRED"]
  },

  "schemas": {
    "measurement_sets": [
      {
        "measurement_set_id": "torque_verification",
        "title": "Torque Verification (OEM-based)",
        "fields": [
          { "field_id": "performed", "type": "BOOLEAN", "required": true },
          { "field_id": "fastener_identifier", "type": "TEXT", "required": false },
          { "field_id": "specified_torque", "type": "NUMBER", "required": false, "precision": 2 },
          { "field_id": "measured_torque", "type": "NUMBER", "required": false, "precision": 2 },
          { "field_id": "torque_unit", "type": "TEXT", "required": false },
          { "field_id": "within_oem_spec", "type": "BOOLEAN", "required": true },
          { "field_id": "torque_wrench_calibrated", "type": "BOOLEAN", "required": true },
          { "field_id": "oem_spec_reference", "type": "TEXT", "required": false },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ]
      }
    ],

    "defect_schema": {
      "defect_id_format": "UUID",
      "fields": [
        { "field_id": "title", "type": "TEXT", "required": true },
        { "field_id": "severity", "type": "ENUM", "enum_ref": "severity", "required": true },
        { "field_id": "standard_reference", "type": "TEXT", "required": false },
        { "field_id": "fastener_role", "type": "ENUM", "enum_ref": "fastener_role", "required": true },
        { "field_id": "fastener_identifier", "type": "TEXT", "required": false },
        {
          "field_id": "location_zone",
          "type": "ENUM",
          "values": ["BASE", "TURRET", "LOWER_BOOM", "UPPER_BOOM", "JIB", "PLATFORM", "OUTRIGGERS", "CHASSIS", "OTHER"],
          "required": false
        },
        { "field_id": "symptoms", "type": "CHOICE_MULTI", "enum_ref": "symptom_type", "required": true },
        { "field_id": "inspection_context", "type": "ENUM", "enum_ref": "inspection_context", "required": false },
        { "field_id": "action_taken", "type": "ENUM", "enum_ref": "action_taken", "required": true },
        { "field_id": "notes", "type": "TEXTAREA", "required": false },
        { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
      ]
    }
  },

  "procedure": {
    "inputs": [
      { "input_id": "inspection_context", "type": "ENUM", "enum_ref": "inspection_context", "required": true }
    ],

    "steps": [
      {
        "step_key": "fasteners_preparation",
        "type": "SETUP",
        "title": "Preparation for bolts and fasteners inspection",
        "standard_reference": "ANSI A92.2-2021 8.2.4(13), 6.6.2",
        "required": true,
        "fields": [
          { "field_id": "worksite_safe", "type": "BOOLEAN", "required": true },
          { "field_id": "device_setup_complete", "type": "BOOLEAN", "required": true },
          { "field_id": "manufacturer_manual_reviewed", "type": "BOOLEAN", "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ],
        "blocking_fail": true
      },

      {
        "step_key": "fasteners_visual_inspection",
        "type": "DEFECT_CAPTURE",
        "title": "Visual inspection of bolts, nuts, washers, and locking devices",
        "standard_reference": "ANSI A92.2-2021 8.2.3(1), 8.2.4(13)",
        "required": true,
        "defect_schema_ref": "defect_schema",
        "ui": {
          "mode": "ADD_DEFECT_ITEMS",
          "guidance": [
            "Inspect bolts for cracks, corrosion, deformation, wear.",
            "Verify nuts, washers, and locking devices are present and intact.",
            "Check for loose, missing, or improperly installed fasteners.",
            "Look for stripped threads, rounded heads, or misalignment."
          ]
        },
        "fields": [
          { "field_id": "no_defects_found", "type": "BOOLEAN", "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false },
          { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
        ]
      },

      {
        "step_key": "fasteners_torque_verification",
        "type": "MEASUREMENT",
        "title": "Torque verification of bolts and fasteners",
        "standard_reference": "ANSI A92.2-2021 8.2.4(13), 6.6.2",
        "required": true,
        "measurement_set_ref": "torque_verification",
        "auto_defect_on": [
          {
            "when": { "path": "measurements.performed", "equals": false },
            "defect": {
              "title": "Torque verification not performed",
              "severity": "SERVICE_REQUIRED",
              "standard_reference": "ANSI A92.2-2021 6.6.2"
            }
          },
          {
            "when": { "path": "measurements.within_oem_spec", "equals": false },
            "defect": {
              "title": "Fastener torque outside OEM specification",
              "severity": "UNSAFE_OUT_OF_SERVICE",
              "standard_reference": "ANSI A92.2-2021 6.6.2"
            }
          },
          {
            "when": { "path": "measurements.torque_wrench_calibrated", "equals": false },
            "defect": {
              "title": "Torque verification performed with uncalibrated wrench",
              "severity": "SERVICE_REQUIRED",
              "standard_reference": "ANSI A92.2-2021 6.6.2"
            }
          }
        ]
      },

      {
        "step_key": "fasteners_critical_review",
        "type": "VISUAL_CHECK",
        "title": "Inspection of structural, load-bearing, and safety-critical fasteners",
        "standard_reference": "ANSI A92.2-2021 4.2, 6.6.2",
        "required": true,
        "fields": [
          { "field_id": "critical_fasteners_verified", "type": "BOOLEAN", "required": true },
          { "field_id": "locking_devices_present", "type": "BOOLEAN", "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ],
        "auto_defect_on": [
          {
            "when": {
              "any": [
                { "path": "fields.critical_fasteners_verified", "equals": false },
                { "path": "fields.locking_devices_present", "equals": false }
              ]
            },
            "defect": {
              "title": "Critical bolt or locking device deficiency",
              "severity": "UNSAFE_OUT_OF_SERVICE",
              "standard_reference": "ANSI A92.2-2021 4.2 / 6.6.2"
            }
          }
        ]
      },

      {
        "step_key": "fasteners_post_repair_testing",
        "type": "FUNCTIONAL_TEST",
        "title": "Post-repair fastener verification",
        "standard_reference": "ANSI A92.2-2021 8.2.4(16)(c)",
        "required": false,
        "visibility_conditions": {
          "any": [
            { "path": "inspection_context", "equals": "POST_REPAIR" },
            { "path": "inspection_context", "equals": "MAJOR_REPAIR" },
            { "path": "inspection_context", "equals": "POST_EVENT" }
          ]
        },
        "fields": [
          { "field_id": "performed", "type": "BOOLEAN", "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ]
      },

      {
        "step_key": "fasteners_design_stress_reference",
        "type": "INSTRUCTION",
        "title": "Reference: Design stress limits (informational)",
        "standard_reference": "ANSI A92.2-2021 4.2",
        "required": false,
        "fields": [
          {
            "field_id": "note",
            "type": "RICH_TEXT",
            "required": false,
            "default": "Section 4.2 design stress limits apply to design/engineering validation. Field inspection verifies correct fasteners, condition, and torque per manufacturer specifications."
          }
        ]
      },

      {
        "step_key": "fasteners_documentation",
        "type": "DOCUMENTATION",
        "title": "Bolts and fasteners inspection documentation",
        "standard_reference": "ANSI A92.2-2021 8.3.2",
        "required": true,
        "fields": [
          { "field_id": "inspection_date", "type": "DATE", "required": true },
          { "field_id": "performed_by_person", "type": "TEXT", "required": true },
          { "field_id": "fasteners_inspected_summary", "type": "TEXTAREA", "required": true },
          { "field_id": "findings_and_actions_summary", "type": "TEXTAREA", "required": false },
          { "field_id": "placard_applied", "type": "BOOLEAN", "required": true }
        ]
      }
    ]
  }
}
