{
  "format": "AF_INSPECTION_TEMPLATE",
  "format_version": 1,
  "template": {
    "template_key": "ansi_a92_2_2021_markings_module",
    "name": "ANSI A92.2-2021 – Markings (Identification / Operational / Instructional) (Module)",
    "status": "DRAFT",
    "standard": { "code": "ANSI/SAIA A92.2", "revision": "2021" },
    "intent": {
      "inspection_kind": "PERIODIC",
      "domain": "AERIAL_DEVICE",
      "tags": ["markings", "labels", "decals", "identification", "warnings", "controls"]
    },
    "policy": {
      "evidence_rules": {
        "photo_required_if_severity_at_least": "SERVICE_REQUIRED",
        "notes_required_on_fail": true,
        "block_finalize_if_required_steps_incomplete": true
      },
      "hashing": {
        "canonicalization": "JSON_CANONICAL_SORT_KEYS_UTF8_NO_WHITESPACE",
        "hash_algorithm": "SHA256"
      }
    }
  },

  "enums": {
    "severity": ["SAFE", "MINOR", "SERVICE_REQUIRED", "UNSAFE_OUT_OF_SERVICE"],
    "inspection_context": ["PERIODIC", "POST_REPAIR", "MAJOR_REPAIR", "POST_EVENT"],
    "marking_category": ["IDENTIFICATION", "OPERATIONAL", "INSTRUCTIONAL", "OTHER"],
    "marking_condition": ["OK", "FADED", "ILLEGIBLE", "MISSING", "PEELING", "DEFACED", "INCORRECT_CONTENT", "WRONG_PLACEMENT"],
    "symptom_type": [
      "MISSING",
      "ILLEGIBLE",
      "DEFACED",
      "PEELING_NOT_SECURE",
      "FADED_DIFFICULT_TO_READ",
      "INCORRECT_CONTENT",
      "NON_COMPLIANT_FORMAT",
      "WRONG_PLACEMENT_VISIBILITY",
      "POTENTIAL_IMPACT_TO_INSULATING_PROPERTIES",
      "OTHER"
    ],
    "action_taken": ["NONE", "CLEANED", "REPLACED", "REPOSITIONED", "REMOVED_FROM_SERVICE", "DEFERRED"]
  },

  "schemas": {
    "defect_schema": {
      "defect_id_format": "UUID",
      "fields": [
        { "field_id": "title", "type": "TEXT", "required": true },
        { "field_id": "severity", "type": "ENUM", "enum_ref": "severity", "required": true },
        { "field_id": "standard_reference", "type": "TEXT", "required": false },
        { "field_id": "marking_category", "type": "ENUM", "enum_ref": "marking_category", "required": true },
        { "field_id": "marking_identifier", "type": "TEXT", "required": false, "help_text": "Example: 'Serial plate', 'Lower controls decal', 'Fall protection warning', etc." },
        { "field_id": "condition", "type": "ENUM", "enum_ref": "marking_condition", "required": false },
        {
          "field_id": "location_zone",
          "type": "ENUM",
          "values": ["BASE", "TURRET", "LOWER_CONTROLS", "UPPER_CONTROLS", "PLATFORM", "CHASSIS", "BOOM", "OUTRIGGERS", "OTHER"],
          "required": false
        },
        { "field_id": "location_detail", "type": "TEXT", "required": false },
        { "field_id": "symptoms", "type": "CHOICE_MULTI", "enum_ref": "symptom_type", "required": true },
        { "field_id": "inspection_context", "type": "ENUM", "enum_ref": "inspection_context", "required": false },
        { "field_id": "action_taken", "type": "ENUM", "enum_ref": "action_taken", "required": true },
        { "field_id": "notes", "type": "TEXTAREA", "required": false },
        { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
      ]
    }
  },

  "procedure": {
    "inputs": [
      { "input_id": "inspection_context", "type": "ENUM", "enum_ref": "inspection_context", "required": true },
      {
        "input_id": "asset_identity_snapshot",
        "type": "ASSET_IDENTITY_SNAPSHOT",
        "required": false,
        "help_text": "Optional: feed make/model/serial/year/rating info so the inspection can verify that required identification markings match recorded asset data."
      }
    ],

    "steps": [
      {
        "step_key": "markings_preparation",
        "type": "SETUP",
        "title": "Preparation for markings inspection",
        "standard_reference": "ANSI A92.2-2021 8.2.4(15), 6.5",
        "required": true,
        "fields": [
          { "field_id": "worksite_safe", "type": "BOOLEAN", "required": true },
          { "field_id": "device_setup_complete", "type": "BOOLEAN", "required": true },
          { "field_id": "manufacturer_manual_reviewed", "type": "BOOLEAN", "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ],
        "blocking_fail": true
      },

      {
        "step_key": "markings_visual_inspection",
        "type": "DEFECT_CAPTURE",
        "title": "Visual inspection of all markings (presence, legibility, durability, placement)",
        "standard_reference": "ANSI A92.2-2021 8.2.3(5), 8.2.4(15)",
        "required": true,
        "defect_schema_ref": "defect_schema",
        "ui": {
          "mode": "ADD_DEFECT_ITEMS",
          "guidance": [
            "Verify identification, operational, and instructional markings are present.",
            "Confirm markings are legible, durable, and securely attached (not peeling/defaced).",
            "Confirm placement is readily visible to operator/maintenance personnel.",
            "Confirm markings do not reduce insulating properties (where applicable)."
          ]
        },
        "fields": [
          { "field_id": "no_defects_found", "type": "BOOLEAN", "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false },
          { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
        ]
      },

      {
        "step_key": "markings_required_content_checklist",
        "type": "CHECKLIST",
        "title": "Verification of required marking content (high-level)",
        "standard_reference": "ANSI A92.2-2021 6.5.2, 4.12.1",
        "required": true,
        "fields": [
          {
            "field_id": "identification_markings_present",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Make/model/serial/year and other required identifying information."
          },
          {
            "field_id": "rated_height_and_capacity_present",
            "type": "BOOLEAN",
            "required": false,
            "help_text": "Rated platform height and rated load capacity markings present."
          },
          {
            "field_id": "insulating_designation_present_if_applicable",
            "type": "BOOLEAN",
            "required": false,
            "help_text": "Insulating/non-insulating designation and qualification voltage/date where applicable."
          },
          {
            "field_id": "control_function_markings_present",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Operational markings describing function of each control."
          },
          {
            "field_id": "warnings_and_instructions_present",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Warnings/cautions/instructions including electrical hazards, fall protection, stowing/transport, etc."
          },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ],
        "auto_defect_on": [
          {
            "when": {
              "any": [
                { "path": "fields.identification_markings_present", "equals": false },
                { "path": "fields.control_function_markings_present", "equals": false },
                { "path": "fields.warnings_and_instructions_present", "equals": false }
              ]
            },
            "defect": {
              "title": "Required markings content missing (identification / controls / warnings)",
              "severity": "SERVICE_REQUIRED",
              "standard_reference": "ANSI A92.2-2021 4.12.1 / 6.5.2"
            }
          }
        ]
      },

      {
        "step_key": "markings_design_and_placement_reference",
        "type": "INSTRUCTION",
        "title": "Reference: Marking design and placement standards (informational)",
        "standard_reference": "ANSI A92.2-2021 4.12.2, 6.5.1",
        "required": false,
        "fields": [
          {
            "field_id": "note",
            "type": "RICH_TEXT",
            "required": false,
            "default": "Markings should be legible/durable and installed where readily visible. Safety label design typically aligns to ANSI/NEMA Z535 series (color code, symbols, product safety signs/labels). Verify OEM requirements for exact content and placement."
          }
        ]
      },

      {
        "step_key": "markings_post_repair_verification",
        "type": "VISUAL_CHECK",
        "title": "Post-repair/replacement markings verification",
        "standard_reference": "ANSI A92.2-2021 8.2.4(16)(c)",
        "required": false,
        "visibility_conditions": {
          "any": [
            { "path": "inspection_context", "equals": "POST_REPAIR" },
            { "path": "inspection_context", "equals": "MAJOR_REPAIR" },
            { "path": "inspection_context", "equals": "POST_EVENT" }
          ]
        },
        "fields": [
          { "field_id": "performed", "type": "BOOLEAN", "required": true },
          { "field_id": "new_markings_match_oem_specs", "type": "BOOLEAN", "required": false },
          { "field_id": "notes", "type": "TEXTAREA", "required": false },
          { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
        ]
      },

      {
        "step_key": "markings_modifications_reference",
        "type": "INSTRUCTION",
        "title": "Reference: Modifications require manufacturer permission",
        "standard_reference": "ANSI A92.2-2021 8.5",
        "required": false,
        "fields": [
          {
            "field_id": "note",
            "type": "RICH_TEXT",
            "required": false,
            "default": "Modifications to markings/placards require prior written permission from the manufacturer; if unavailable, approval by equivalent entity after engineering analysis."
          }
        ]
      },

      {
        "step_key": "markings_documentation",
        "type": "DOCUMENTATION",
        "title": "Markings inspection documentation",
        "standard_reference": "ANSI A92.2-2021 8.3.2",
        "required": true,
        "fields": [
          { "field_id": "inspection_date", "type": "DATE", "required": true },
          { "field_id": "performed_by_person", "type": "TEXT", "required": true },
          { "field_id": "markings_inspected_summary", "type": "TEXTAREA", "required": true },
          { "field_id": "findings_and_actions_summary", "type": "TEXTAREA", "required": false },
          { "field_id": "placard_applied", "type": "BOOLEAN", "required": true }
        ]
      }
    ]
  }
}
