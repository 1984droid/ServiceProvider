{
  "format": "AF_INSPECTION_TEMPLATE",
  "format_version": 1,
  "template": {
    "template_key": "ansi_a92_2_2021_hydraulic_pneumatic_filters_module",
    "name": "ANSI A92.2-2021 – Hydraulic & Pneumatic Filters (Module)",
    "status": "DRAFT",
    "standard": { "code": "ANSI/SAIA A92.2", "revision": "2021" },
    "intent": {
      "inspection_kind": "PERIODIC",
      "domain": "AERIAL_DEVICE",
      "tags": ["hydraulic", "pneumatic", "filters", "cleanliness", "contamination"]
    },
    "policy": {
      "evidence_rules": {
        "photo_required_if_severity_at_least": "SERVICE_REQUIRED",
        "notes_required_on_fail": true,
        "block_finalize_if_required_steps_incomplete": true
      },
      "hashing": {
        "canonicalization": "JSON_CANONICAL_SORT_KEYS_UTF8_NO_WHITESPACE",
        "hash_algorithm": "SHA256"
      }
    }
  },

  "enums": {
    "severity": ["SAFE", "MINOR", "SERVICE_REQUIRED", "UNSAFE_OUT_OF_SERVICE"],
    "step_status": ["PASS", "FAIL", "NOT_PERFORMED", "NOT_APPLICABLE"],
    "inspection_context": ["PERIODIC", "POST_REPAIR", "MAJOR_REPAIR", "POST_EVENT"],
    "system_type": ["HYDRAULIC", "PNEUMATIC"],
    "filter_type": ["RETURN", "PRESSURE", "SUCTION", "BREATHER", "INLINE", "DRYER", "OTHER"],
    "symptom_type": [
      "HOUSING_CRACK",
      "DEFORMATION",
      "CORROSION",
      "LEAK",
      "LOOSE_CONNECTION",
      "MISSING_FASTENERS",
      "SEAL_GASKET_DAMAGE",
      "ELEMENT_CONTAMINATION",
      "CLOGGED_RESTRICTED",
      "BYPASS_OPEN_SUSPECTED",
      "DIRT_DEBRIS_MOISTURE",
      "IMPROPER_INSTALLATION_ALIGNMENT",
      "OTHER"
    ],
    "action_taken": ["NONE", "CLEANED", "TIGHTENED", "REPAIRED", "REPLACED", "REMOVED_FROM_SERVICE", "DEFERRED"],
    "cleanliness_result": ["PASS", "FAIL", "UNKNOWN"]
  },

  "schemas": {
    "measurement_sets": [
      {
        "measurement_set_id": "filter_performance_measurements",
        "title": "Filter Performance / Cleanliness (Optional, OEM-based)",
        "fields": [
          {
            "field_id": "performed",
            "label": "Performance/cleanliness verification performed?",
            "type": "BOOLEAN",
            "required": true
          },
          {
            "field_id": "oem_spec_reference",
            "label": "OEM spec/procedure reference",
            "type": "TEXT",
            "required": false
          },
          {
            "field_id": "cleanliness_result",
            "label": "Cleanliness/contamination result",
            "type": "ENUM",
            "enum_ref": "cleanliness_result",
            "required": true
          },
          {
            "field_id": "measured_value",
            "label": "Measured value (optional)",
            "type": "NUMBER",
            "required": false,
            "precision": 2
          },
          {
            "field_id": "measured_unit",
            "label": "Unit (optional)",
            "type": "TEXT",
            "required": false
          },
          {
            "field_id": "notes",
            "label": "Notes",
            "type": "TEXTAREA",
            "required": false
          }
        ]
      }
    ],

    "defect_schema": {
      "defect_id_format": "UUID",
      "fields": [
        { "field_id": "title", "type": "TEXT", "required": true },
        { "field_id": "severity", "type": "ENUM", "enum_ref": "severity", "required": true },
        { "field_id": "standard_reference", "type": "TEXT", "required": false },
        { "field_id": "system_type", "type": "ENUM", "enum_ref": "system_type", "required": true },
        { "field_id": "filter_type", "type": "ENUM", "enum_ref": "filter_type", "required": false },
        { "field_id": "filter_identifier", "type": "TEXT", "required": false },
        { "field_id": "symptoms", "type": "CHOICE_MULTI", "enum_ref": "symptom_type", "required": true },
        {
          "field_id": "location_zone",
          "type": "ENUM",
          "values": ["BASE", "TURRET", "LOWER_BOOM", "UPPER_BOOM", "JIB", "PLATFORM", "OUTRIGGERS", "CHASSIS", "OTHER"],
          "required": false
        },
        { "field_id": "location_detail", "type": "TEXT", "required": false },
        { "field_id": "inspection_context", "type": "ENUM", "enum_ref": "inspection_context", "required": false },
        { "field_id": "action_taken", "type": "ENUM", "enum_ref": "action_taken", "required": true },
        { "field_id": "notes", "type": "TEXTAREA", "required": false },
        { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
      ]
    }
  },

  "procedure": {
    "inputs": [
      { "input_id": "inspection_context", "type": "ENUM", "enum_ref": "inspection_context", "required": true },
      { "input_id": "asset_capabilities", "type": "ASSET_CAPABILITIES", "required": false }
    ],

    "steps": [
      {
        "step_key": "filters_preparation",
        "type": "SETUP",
        "title": "Preparation for hydraulic and pneumatic filter inspection",
        "standard_reference": "ANSI A92.2-2021 8.2.4(10)",
        "required": true,
        "fields": [
          { "field_id": "worksite_safe", "type": "BOOLEAN", "required": true },
          { "field_id": "device_setup_complete", "type": "BOOLEAN", "required": true },
          { "field_id": "manufacturer_manual_reviewed", "type": "BOOLEAN", "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ],
        "blocking_fail": true
      },

      {
        "step_key": "filters_visual_inspection",
        "type": "DEFECT_CAPTURE",
        "title": "Visual inspection of filter housings, elements, and connections",
        "standard_reference": "ANSI A92.2-2021 8.2.3(1), 8.2.4(10)",
        "required": true,
        "defect_schema_ref": "defect_schema",
        "ui": {
          "mode": "ADD_DEFECT_ITEMS",
          "guidance": [
            "Inspect filter housing for cracks, deformation, corrosion.",
            "Inspect filter elements for dirt/debris/contamination or clogging.",
            "Inspect connections for loose/damaged fittings and leaks.",
            "Inspect seals/gaskets for wear/cracks/leaks."
          ]
        },
        "fields": [
          {
            "field_id": "no_defects_found",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "If true, you must have zero defects recorded for this step."
          },
          { "field_id": "notes", "type": "TEXTAREA", "required": false },
          { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
        ],
        "validations": [
          {
            "validation_id": "no_defects_true_requires_zero_defects",
            "type": "CONSISTENCY",
            "rule": "IF fields.no_defects_found == true THEN defect_count == 0"
          }
        ]
      },

      {
        "step_key": "filters_functional_observation",
        "type": "FUNCTIONAL_TEST",
        "title": "Functional observation of system operation related to filtration",
        "standard_reference": "ANSI A92.2-2021 8.2.4(10), 4.6.5",
        "required": true,
        "fields": [
          {
            "field_id": "operated_system",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Operate hydraulic/pneumatic systems and observe flow/pressure behavior per OEM procedure."
          },
          {
            "field_id": "anomalies_observed",
            "type": "CHOICE_MULTI",
            "choices": ["UNUSUAL_NOISE", "VIBRATION", "ERRATIC_MOVEMENT", "LOW_FLOW_SUSPECTED", "PRESSURE_FLUCTUATION", "OTHER"],
            "required": false
          },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ],
        "auto_defect_on": [
          {
            "when": { "path": "fields.operated_system", "equals": false },
            "defect": {
              "title": "System not operated; filtration-related function not observed",
              "severity": "SERVICE_REQUIRED",
              "standard_reference": "ANSI A92.2-2021 8.2.4(10)"
            }
          }
        ]
      },

      {
        "step_key": "filters_replacement_actions",
        "type": "ACTION_RECORD",
        "title": "Filter replacement / corrective actions (if needed)",
        "standard_reference": "ANSI A92.2-2021 8.2.4(10), 4.6.5",
        "required": false,
        "fields": [
          {
            "field_id": "filters_replaced",
            "type": "BOOLEAN",
            "required": true
          },
          {
            "field_id": "replacement_follows_oem",
            "type": "BOOLEAN",
            "required": false,
            "help_text": "Confirm replacement followed manufacturer instructions and correct spec filter used."
          },
          { "field_id": "replacement_details", "type": "TEXTAREA", "required": false },
          { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
        ]
      },

      {
        "step_key": "filters_cleanliness_verification_optional",
        "type": "MEASUREMENT",
        "title": "Cleanliness / filtration effectiveness verification (optional, OEM-based)",
        "standard_reference": "ANSI A92.2-2021 4.6.5",
        "required": false,
        "measurement_set_ref": "filter_performance_measurements",
        "auto_defect_on": [
          {
            "when": {
              "all": [
                { "path": "measurements.performed", "equals": true },
                { "path": "measurements.cleanliness_result", "equals": "FAIL" }
              ]
            },
            "defect": {
              "title": "Fluid cleanliness/filtration effectiveness not acceptable per OEM criteria",
              "severity": "SERVICE_REQUIRED",
              "standard_reference": "ANSI A92.2-2021 4.6.5"
            }
          }
        ]
      },

      {
        "step_key": "filters_post_repair_testing",
        "type": "FUNCTIONAL_TEST",
        "title": "Post-repair functional verification",
        "standard_reference": "ANSI A92.2-2021 8.2.4(16)(c)",
        "required": false,
        "visibility_conditions": {
          "any": [
            { "path": "inspection_context", "equals": "POST_REPAIR" },
            { "path": "inspection_context", "equals": "MAJOR_REPAIR" },
            { "path": "inspection_context", "equals": "POST_EVENT" }
          ]
        },
        "fields": [
          { "field_id": "performed", "type": "BOOLEAN", "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ]
      },

      {
        "step_key": "filters_oem_instructions_reference",
        "type": "INSTRUCTION",
        "title": "Reference: Manufacturer instructions must include cleanliness levels and intervals",
        "standard_reference": "ANSI A92.2-2021 6.4",
        "required": false,
        "fields": [
          {
            "field_id": "note",
            "type": "RICH_TEXT",
            "required": false,
            "default": "Manufacturer maintenance manual should specify filter cleanliness levels and replacement intervals. Record OEM reference used for decisions."
          }
        ]
      },

      {
        "step_key": "filters_modifications_reference",
        "type": "INSTRUCTION",
        "title": "Reference: Modifications require manufacturer permission",
        "standard_reference": "ANSI A92.2-2021 8.5",
        "required": false,
        "fields": [
          {
            "field_id": "note",
            "type": "RICH_TEXT",
            "required": false,
            "default": "Modifications to filters/filtration systems require manufacturer permission; if unavailable, approval by equivalent entity after engineering analysis."
          }
        ]
      },

      {
        "step_key": "filters_documentation",
        "type": "DOCUMENTATION",
        "title": "Filters inspection documentation",
        "standard_reference": "ANSI A92.2-2021 8.3.2",
        "required": true,
        "fields": [
          { "field_id": "inspection_date", "type": "DATE", "required": true },
          { "field_id": "performed_by_person", "type": "TEXT", "required": true },
          { "field_id": "filters_inspected_summary", "type": "TEXTAREA", "required": true },
          { "field_id": "findings_and_actions_summary", "type": "TEXTAREA", "required": false },
          { "field_id": "placard_applied", "type": "BOOLEAN", "required": true }
        ]
      }
    ]
  }
}
