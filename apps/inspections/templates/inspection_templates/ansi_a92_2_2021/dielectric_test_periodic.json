          {
            "field_id": "boom_positioned",
            "label": "Boom positioned per appropriate figure?",
            "type": "ENUM",
            "enum_ref": "boom_position_figure",
            "required": true,
            "help_text": "Section 5.4.3.2(5) - Clear from potential grounding structures"
          },
          {
            "field_id": "setup_notes",
            "label": "Test Setup Notes",
            "type": "TEXT_AREA",
            "required": false
          }
        ],
        "blocking_fail": true
      },
      {
        "step_key": "execute_test_method_a_ac",
        "type": "MEASUREMENT",
        "title": "Execute AC Test per Table 2 (Method A)",
        "standard_reference": "ANSI A92.2-2021 Table 2 / Section 5.4.3",
        "required": true,
        "visibility_conditions": {
          "path": "inputs.test_method",
          "equals": "METHOD_A_AC_TABLE2"
        },
        "measurement_set_ref": "dielectric_test_table2_ac",
        "fields": [
          {
            "field_id": "voltage_maintained_within_tolerance",
            "label": "Test voltage maintained within Â±3% for entire duration?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.5.2 - Voltage tolerance requirement"
          },
          {
            "field_id": "current_stabilized",
            "label": "Leakage current stabilized before recording final value?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Wait for current to stabilize before recording"
          },
          {
            "field_id": "test_completed_successfully",
            "label": "Test completed without breakdown or flashover?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "No breakdown indicates insulation integrity"
          },
          {
            "field_id": "test_notes",
            "label": "Test Execution Notes",
            "type": "TEXT_AREA",
            "required": false
          }
        ]
      },
      {
        "step_key": "execute_test_method_b_dc",
        "type": "MEASUREMENT",
        "title": "Execute DC Test per Table 2 (Method B)",
        "standard_reference": "ANSI A92.2-2021 Table 2 / Section 5.4.3",
        "required": true,
        "visibility_conditions": {
          "path": "inputs.test_method",
          "equals": "METHOD_B_DC_TABLE2"
        },
        "measurement_set_ref": "dielectric_test_table2_dc",
        "fields": [
          {
            "field_id": "voltage_maintained_within_tolerance",
            "label": "Test voltage maintained within Â±3% for entire duration?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.5.2 - Voltage tolerance requirement"
          },
          {
            "field_id": "current_stabilized",
            "label": "Leakage current stabilized before recording final value?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "DC test requires longer stabilization time"
          },
          {
            "field_id": "test_completed_successfully",
            "label": "Test completed without breakdown or flashover?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "No breakdown indicates insulation integrity"
          },
          {
            "field_id": "test_notes",
            "label": "Test Execution Notes",
            "type": "TEXT_AREA",
            "required": false
          }
        ]
      },
      {
        "step_key": "execute_test_method_c_before_use",
        "type": "MEASUREMENT",
        "title": "Execute Before Use Test per Table 3 (Method C)",
        "standard_reference": "ANSI A92.2-2021 Table 3 / Section 5.4.3.1(11)(c)",
        "required": true,
        "visibility_conditions": {
          "path": "inputs.test_method",
          "equals": "METHOD_C_BEFORE_USE_TABLE3"
        },
        "measurement_set_ref": "before_use_test_table3",
        "fields": [
          {
            "field_id": "vehicle_grounded",
            "label": "Vehicle grounded during test?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.4.3.1(11)(c) - Vehicle must be grounded"
          },
          {
            "field_id": "boom_raised_into_line",
            "label": "Boom raised into energized line?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Field test using actual energized power line"
          },
          {
            "field_id": "line_voltage_within_limits",
            "label": "Line voltage â‰¥ max working voltage AND â‰¤ qualification voltage?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Critical safety requirement - voltage must be in acceptable range"
          },
          {
            "field_id": "test_completed_safely",
            "label": "Test completed safely without incident?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "No arcing, flashover, or other incidents"
          },
          {
            "field_id": "test_notes",
            "label": "Test Execution Notes",
            "type": "TEXT_AREA",
            "required": false
          }
        ]
      },
      {
        "step_key": "chassis_insulating_system_test",
        "type": "MEASUREMENT",
        "title": "Chassis Insulating System Test (if equipped)",
        "standard_reference": "ANSI A92.2-2021 Section 5.4.3.4",
        "required": false,
        "visibility_conditions": {
          "path": "inputs.has_chassis_insulating_system",
          "equals": "YES"
        },
        "measurement_set_ref": "chassis_insulating_system_test",
        "fields": [
          {
            "field_id": "test_method",
            "label": "Test method",
            "type": "ENUM",
            "enum_ref": "chassis_test_method",
            "required": true,
            "help_text": "Section 5.4.3.4(5) - AC: 35kV for 3min or DC: 50kV for 3min"
          },
          {
            "field_id": "voltage_applied_to_metal_above_system",
            "label": "Voltage applied to metal above insulating system?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.4.3.4(1)"
          },
          {
            "field_id": "hydraulic_lines_filled",
            "label": "All hydraulic lines crossing system filled with oil?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.4.3.4(2)"
          },
          {
            "field_id": "boom_positioned_fig3",
            "label": "Boom positioned per Figure 3?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.4.3.4(4)"
          },
          {
            "field_id": "test_completed_successfully",
            "label": "Test completed without breakdown?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "No breakdown indicates chassis system integrity"
          },
          {
            "field_id": "test_notes",
            "label": "Chassis System Test Notes",
            "type": "TEXT_AREA",
            "required": false
          }
        ]
      },
      {
        "step_key": "test_results_evaluation",
        "type": "SETUP",
        "title": "Test Results Evaluation",
        "standard_reference": "ANSI A92.2-2021 Tables 2 & 3",
        "required": true,
        "fields": [
          {
            "field_id": "test_duration_met",
            "label": "Minimum test duration met per standard?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "AC: 60s min, DC: 180s min, Before Use: 180s min"
          },
          {
            "field_id": "leakage_current_within_limits",
            "label": "Leakage current within acceptable limits per Table 2 or Table 3?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Automatic validation rules will check specific limits"
          },
          {
            "field_id": "no_breakdown_occurred",
            "label": "No breakdown or flashover occurred during test?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Breakdown indicates insulation failure"
          },
          {
            "field_id": "test_passed",
            "label": "Dielectric test PASSED?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Check YES only if all requirements met"
          },
          {
            "field_id": "test_results_summary",
            "label": "Test Results Summary",
            "type": "TEXT_AREA",
            "required": true,
            "help_text": "Summary of test results and findings"
          }
        ]
      },
      {
        "step_key": "test_documentation",
        "type": "SETUP",
        "title": "Test Documentation and Certification",
        "standard_reference": "ANSI A92.2-2021 Sections 5.6.3, 7.11.2, 8.3.2",
        "required": true,
        "fields": [
          {
            "field_id": "placard_applied_to_mewp",
            "label": "Placard indicating test completion date applied to MEWP?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Sections 7.11.2 & 8.3.2 - Required by standard"
          },
          {
            "field_id": "placard_location",
            "label": "Placard location on equipment",
            "type": "TEXT",
            "required": false,
            "help_text": "Where placard was affixed"
          },
          {
            "field_id": "report_provided_to_owner",
            "label": "Certified test report will be provided to owner?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.6.2 - Required by standard"
          },
          {
            "field_id": "records_filed",
            "label": "Test records filed in equipment permanent file?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 7.11 - Permanent record keeping requirement"
          },
          {
            "field_id": "next_test_due_date",
            "label": "Next Dielectric Test Due Date",
            "type": "DATE",
            "required": true,
            "help_text": "Per periodic test schedule or manufacturer requirements"
          },
          {
            "field_id": "tester_signature",
            "label": "Signature of person performing test",
            "type": "TEXT",
            "required": true,
            "help_text": "Section 5.6.3(10) - Required certification"
          },
          {
            "field_id": "documentation_notes",
            "label": "Documentation Notes",
            "type": "TEXT_AREA",
            "required": false
          }
        ]
      }
    ]
  },
  "rules": [
    {
      "rule_id": "table2_ac_duration_60_seconds",
      "title": "AC test duration must be 60 seconds minimum (Table 2)",
      "standard_reference": "ANSI A92.2-2021 Table 2",
      "when": {
        "path": "inputs.test_method",
        "equals": "METHOD_A_AC_TABLE2"
      },
      "assert": {
        "type": "NUMERIC_GTE",
        "left": {
          "path": "execute_test_method_a_ac.test_duration_seconds"
        },
        "right": 60
      },
      "on_fail": {
        "severity": "UNSAFE_OUT_OF_SERVICE",
        "defect_title": "AC test duration less than required 60 seconds",
        "defect_description": "Test invalid - AC dielectric test must be performed for minimum 60 seconds per Table 2."
      }
    },
    {
      "rule_id": "table2_dc_duration_180_seconds",
      "title": "DC test duration must be 180 seconds minimum (Table 2)",
      "standard_reference": "ANSI A92.2-2021 Table 2",
      "when": {
        "path": "inputs.test_method",
        "equals": "METHOD_B_DC_TABLE2"
      },
      "assert": {
        "type": "NUMERIC_GTE",
        "left": {
          "path": "execute_test_method_b_dc.test_duration_seconds"
        },
        "right": 180
      },
      "on_fail": {
        "severity": "UNSAFE_OUT_OF_SERVICE",
        "defect_title": "DC test duration less than required 180 seconds",
        "defect_description": "Test invalid - DC dielectric test must be performed for minimum 180 seconds per Table 2."
      }
    },
    {
      "rule_id": "table3_duration_180_seconds",
      "title": "Before use test duration must be 180 seconds minimum (Table 3)",
      "standard_reference": "ANSI A92.2-2021 Table 3",
      "when": {
        "path": "inputs.test_method",
        "equals": "METHOD_C_BEFORE_USE_TABLE3"
      },
      "assert": {
        "type": "NUMERIC_GTE",
        "left": {
          "path": "execute_test_method_c_before_use.test_duration_seconds"
        },
        "right": 180
      },
      "on_fail": {
        "severity": "UNSAFE_OUT_OF_SERVICE",
        "defect_title": "Before use test duration less than required 180 seconds",
        "defect_description": "Test invalid - Before use test must be performed for minimum 180 seconds per Table 3."
      }
    },
    {
      "rule_id": "dielectric_test_must_pass",
      "title": "Dielectric test must pass for unit to be safe for operation",
      "standard_reference": "ANSI A92.2-2021 Section 5.4",
      "assert": {
        "type": "BOOLEAN_TRUE",
        "path": "test_results_evaluation.test_passed"
      },
      "on_fail": {
        "severity": "UNSAFE_OUT_OF_SERVICE",
        "defect_title": "CRITICAL: Dielectric test FAILED",
        "defect_description": "Unit FAILED dielectric testing and must be tagged OUT OF SERVICE. Unit may not be used near energized conductors until insulation is repaired and unit passes retest."
      }
    }
  ]
}