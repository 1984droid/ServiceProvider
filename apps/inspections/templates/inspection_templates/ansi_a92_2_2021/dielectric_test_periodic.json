            "required": false,
            "help_text": "Section 5.4.3.2(3) - Per Figures 2, 2A, 3, or 4"
          },
          {
            "field_id": "chassis_system_shunted",
            "label": "Chassis insulating system shunted if equipped?",
            "type": "BOOLEAN",
            "required": false,
            "help_text": "Section 5.4.3.2(4) - Per Figure 3A"
          },
          {
            "field_id": "test_method_setup",
            "label": "Test setup per selected method?",
            "type": "ENUM",
            "enum_ref": "test_setup_method",
            "required": true,
            "help_text": "Section 5.4.3.2(5) - See figures based on test method"
          },
          {
            "field_id": "meter_connected",
            "label": "Current meter connected via shielded cable and grounded?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.4.3.2(5)(a) or (b)"
