{
  "format": "AF_INSPECTION_TEMPLATE",
  "format_version": 1,
  "template": {
    "template_key": "ansi_a92_2_periodic_dielectric_test",
    "name": "ANSI A92.2-2021 Periodic Dielectric Test",
    "status": "PUBLISHED",
    "standard": {
      "code": "ANSI/SAIA A92.2",
      "revision": "2021"
    },
    "intent": {
      "inspection_kind": "PERIODIC",
      "domain": "AERIAL_DEVICE",
      "tags": [
        "dielectric",
        "electrical",
        "insulating",
        "periodic",
        "high-voltage",
        "leakage-current"
      ]
    },
    "applicability": {
      "asset_types": [
        "EQUIPMENT"
      ],
      "equipment_types": [
        "A92_2_AERIAL"
      ],
      "notes": "For insulating aerial devices requiring periodic electrical testing per ANSI A92.2-2021 Section 5.3.3 and 8.2.4(16). This test verifies the integrity of the insulating system by measuring leakage current at specified test voltages. CRITICAL SAFETY TEST - Must be performed by qualified personnel with proper test equipment meeting IEEE Std. 4-2013 requirements."
    },
    "policy": {
      "evidence_rules": {
        "photo_required_if_severity_at_least": "SERVICE_REQUIRED",
        "notes_required_on_fail": true,
        "block_finalize_if_required_steps_incomplete": true
      },
      "hashing": {
        "canonicalization": "JSON_CANONICAL_SORT_KEYS_UTF8_NO_WHITESPACE",
        "hash_algorithm": "SHA256"
      }
    }
  },
