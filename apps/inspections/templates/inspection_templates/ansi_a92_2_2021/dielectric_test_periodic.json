  },
  "schemas": {
    "measurement_sets": [
      {
        "measurement_set_id": "dielectric_test_table2_ac",
        "title": "AC Dielectric Test Measurements (Table 2)",
        "fields": [
          {
            "field_id": "rated_line_voltage_kv",
            "label": "Rated line voltage (kV)",
            "type": "NUMBER",
            "required": true,
            "precision": 0,
            "min": 1,
            "help_text": "Voltage rating from unit nameplate"
          },
          {
            "field_id": "applied_test_voltage_kv",
            "label": "Applied test voltage (kV RMS)",
            "type": "NUMBER",
            "required": true,
            "precision": 1,
            "min": 1,
            "help_text": "Per Table 2 - voltage applied during test"
          },
          {
            "field_id": "test_duration_seconds",
            "label": "Test duration (seconds)",
            "type": "NUMBER",
            "required": true,
            "precision": 0,
            "min": 60,
            "help_text": "Must be minimum 60 seconds for AC test"
          },
          {
            "field_id": "final_leakage_current_microamps",
            "label": "Final leakage current (ÂµA RMS)",
            "type": "NUMBER",
            "required": true,
            "precision": 2,
            "min": 0,
            "help_text": "Leakage current at end of test period"
          }
        ]
      },
      {
        "measurement_set_id": "dielectric_test_table2_dc",
        "title": "DC Dielectric Test Measurements (Table 2)",
        "fields": [
          {
            "field_id": "rated_line_voltage_kv",
            "label": "Rated line voltage (kV)",
            "type": "NUMBER",
            "required": true,
            "precision": 0,
            "min": 1,
            "help_text": "Voltage rating from unit nameplate"
          },
          {
            "field_id": "applied_test_voltage_kv",
            "label": "Applied test voltage (kV DC)",
            "type": "NUMBER",
            "required": true,
            "precision": 1,
            "min": 1,
            "help_text": "Per Table 2 - DC voltage applied during test"
          },
          {
            "field_id": "test_duration_seconds",
            "label": "Test duration (seconds)",
            "type": "NUMBER",
            "required": true,
            "precision": 0,
            "min": 180,
            "help_text": "Must be minimum 180 seconds for DC test"
          },
          {
            "field_id": "final_leakage_current_microamps",
            "label": "Final leakage current (ÂµA)",
            "type": "NUMBER",
            "required": true,
            "precision": 2,
            "min": 0,
            "help_text": "DC leakage current at end of test period"
          }
        ]
      },
      {
        "measurement_set_id": "before_use_test_table3",
        "title": "Before Use Test Measurements (Table 3)",
        "fields": [
          {
            "field_id": "line_voltage_kv",
            "label": "Energized line voltage (kV)",
            "type": "NUMBER",
            "required": true,
            "precision": 1,
            "min": 0.1,
            "help_text": "Actual line voltage during field test"
          },
          {
            "field_id": "test_duration_seconds",
            "label": "Test duration (seconds)",
            "type": "NUMBER",
            "required": true,
            "precision": 0,
            "min": 180,
            "help_text": "Must be minimum 180 seconds"
          },
          {
            "field_id": "measured_current_microamps",
            "label": "Measured leakage current (ÂµA)",
            "type": "NUMBER",
            "required": true,
            "precision": 3,
            "min": 0,
            "help_text": "Leakage current measured during field test"
          },
          {
            "field_id": "test_voltage_type",
            "label": "Line voltage type",
            "type": "ENUM",
            "enum_ref": "test_voltage_type",
            "required": true,
            "help_text": "AC or DC line voltage"
          }
        ]
      },
      {
        "measurement_set_id": "chassis_insulating_system_test",
        "title": "Chassis Insulating System Test Measurements",
        "fields": [
          {
            "field_id": "test_voltage_kv",
            "label": "Applied test voltage (kV)",
            "type": "NUMBER",
            "required": true,
            "precision": 0,
            "min": 1,
            "help_text": "AC: 35kV or DC: 50kV per Section 5.4.3.4(5)"
          },
          {
            "field_id": "test_duration_seconds",
            "label": "Test duration (seconds)",
            "type": "NUMBER",
            "required": true,
            "precision": 0,
            "min": 180,
            "help_text": "Must be 180 seconds (3 minutes)"
          },
          {
            "field_id": "final_current_value",
            "label": "Final current value",
            "type": "NUMBER",
            "required": true,
            "precision": 3,
            "min": 0,
            "help_text": "AC: â‰¤3 mA, DC: â‰¤100 ÂµA"
          },
          {
            "field_id": "current_unit",
            "label": "Current measurement unit",
            "type": "ENUM",
            "enum_ref": "current_unit",
            "required": true,
            "help_text": "Microamps or milliamps"
          }
        ]
      }
    ],
    "defect_schema": {
      "defect_id_format": "UUID",
      "fields": [
        {
          "field_id": "title",
          "type": "TEXT",
          "required": true
        },
        {
          "field_id": "severity",
          "type": "ENUM",
          "enum_ref": "severity",
          "required": true
        },
        {
          "field_id": "description",
          "type": "TEXT_AREA",
          "required": true
        },
        {
          "field_id": "component",
          "type": "TEXT",
          "required": false
        },
        {
          "field_id": "location",
          "type": "ENUM",
          "required": false,
          "enum_ref": "equipment_location"
        },
        {
          "field_id": "photo_evidence",
          "type": "PHOTO",
          "required": false
        },
        {
          "field_id": "corrective_action",
          "type": "TEXT_AREA",
          "required": false
        },
        {
          "field_id": "standard_reference",
          "type": "TEXT",
          "required": true
        }
      ]
    }
  },
  "procedure": {
    "inputs": [
      {
        "input_id": "unit_category",
        "label": "Unit Category (from nameplate)",
        "type": "ENUM",
        "enum_ref": "unit_category",
        "required": true,
        "help_text": "Insulating aerial device category per ANSI A92.2-2021 Section 5.1.2 (A, B, C, D, or E)"
      },
      {
        "input_id": "test_method",
        "label": "Test Method",
        "type": "ENUM",
        "enum_ref": "test_method",
        "required": true,
        "help_text": "Select test method per ANSI A92.2-2021 Section 5.4.3: Method A (AC per Table 2), Method B (DC per Table 2), or Method C (Before Use per Table 3)"
      },
      {
        "input_id": "has_chassis_insulating_system",
        "label": "Equipped with chassis insulating system?",
        "type": "ENUM",
        "enum_ref": "yes_no",
        "required": true,
        "help_text": "Per Section 5.2.5 - Required for Cat C/D articulated units to work near energized lines"
      }
    ],
    "steps": [
      {
        "step_key": "test_information",
        "type": "SETUP",
        "title": "Dielectric Test Information",
        "standard_reference": "ANSI A92.2-2021 Section 5.6.3",
        "required": true,
        "fields": [
          {
            "field_id": "test_date",
            "label": "Test Date",
            "type": "DATE",
            "required": true
          },
          {
            "field_id": "testing_entity_name",
            "label": "Name of entity performing test",
            "type": "TEXT",
            "required": true,
            "help_text": "Section 5.6.3(1) - Company name"
          },
          {
            "field_id": "tester_name",
            "label": "Name of person performing test",
            "type": "TEXT",
            "required": true
          },
          {
            "field_id": "tester_qualifications",
            "label": "Tester qualifications/certification",
            "type": "TEXT",
            "required": true,
            "help_text": "Must be qualified personnel per Section 5.4"
          },
          {
            "field_id": "device_make",
            "label": "Aerial device make",
            "type": "TEXT",
            "required": true,
            "help_text": "Section 5.6.3(2)"
          },
          {
            "field_id": "device_model",
            "label": "Aerial device model",
            "type": "TEXT",
            "required": true,
            "help_text": "Section 5.6.3(2)"
          },
          {
            "field_id": "device_serial_number",
            "label": "Aerial device serial number",
            "type": "TEXT",
            "required": true,
            "help_text": "Section 5.6.3(2)"
          },
          {
            "field_id": "rated_line_voltage_kv",
            "label": "Rated line voltage (kV)",
            "type": "NUMBER",
            "required": true,
            "precision": 1,
            "min": 0.1,
            "help_text": "Section 5.6.3(4) - From nameplate"
          },
          {
            "field_id": "test_notes",
            "label": "Test Information Notes",
            "type": "TEXT_AREA",
            "required": false
          }
        ]
      },
      {
        "step_key": "pre_test_visual_inspection",
        "type": "VISUAL_INSPECTION",
        "title": "Pre-Test Visual Inspection of Insulating Components",
        "standard_reference": "ANSI A92.2-2021 Section 5.4.1",
        "required": true,
        "defect_schema_ref": "defect_schema",
        "ui": {
          "mode": "ADD_DEFECT_ITEMS",
          "guidance": [
            "Thoroughly inspect all insulating components before testing",
            "Check for dirt, oil, moisture, salt, or other contamination",
            "Look for cracks, checks, or other visible damage to insulating sections",
            "Verify no conditions exist that would compromise the insulation",
            "Clean contaminated components before proceeding with test",
            "Document any damage or conditions found"
          ]
        },
        "fields": [
          {
            "field_id": "insulating_components_clean",
            "label": "Insulating components clean and free of contamination?",
            "type": "ENUM",
            "enum_ref": "cleanliness_status",
            "required": true,
            "help_text": "Check for dirt, oil, moisture, salt, or other contamination"
          },
          {
            "field_id": "visible_damage",
            "label": "Any visible damage to insulating components?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Cracks, checks, deterioration of insulating material"
          },
          {
            "field_id": "conditions_compromising_insulation",
            "label": "Any conditions that compromise insulation?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Missing covers, broken seals, water intrusion, etc."
          },
          {
            "field_id": "visual_inspection_notes",
            "label": "Visual Inspection Notes",
            "type": "TEXT_AREA",
            "required": false,
            "help_text": "Document any issues found"
          }
        ],
        "auto_defect_on": [
          {
            "when": {
              "path": "insulating_components_clean",
              "equals": "CONTAMINATED"
            },
            "defect": {
              "title": "Insulating components contaminated - must be cleaned before test",
              "severity": "SERVICE_REQUIRED",
              "description": "Insulating components must be clean and free of contamination before dielectric testing per Section 5.4.1.",
              "standard_reference": "ANSI A92.2-2021 Section 5.4.3.1(1)-(4) & 8.2.4(16)"
            }
          },
          {
            "when": {
              "path": "visible_damage",
              "equals": true
            },
            "defect": {
              "title": "CRITICAL: Visible damage to insulating components",
              "severity": "UNSAFE_OUT_OF_SERVICE",
              "description": "Visible damage found on insulating components. Unit must not be operated until damage is repaired and unit is retested.",
              "standard_reference": "ANSI A92.2-2021 Section 5.4.3.1(1)-(4) & 8.2.4(16)"
            }
          },
          {
            "when": {
              "path": "conditions_compromising_insulation",
              "equals": true
            },
            "defect": {
              "title": "Conditions found that compromise insulation integrity",
              "severity": "UNSAFE_OUT_OF_SERVICE",
              "description": "Conditions found that may compromise the insulating system. Must be corrected before testing.",
              "standard_reference": "ANSI A92.2-2021 Section 5.4.3.1(1)-(4) & 8.2.4(16)"
            }
          }
        ],
        "blocking_fail": true
      },
      {
        "step_key": "test_equipment_verification",
        "type": "SETUP",
        "title": "Test Equipment Verification",
        "standard_reference": "ANSI A92.2-2021 Section 5.5",
        "required": true,
        "fields": [
          {
            "field_id": "test_equipment_meets_ieee_std_4",
            "label": "Test equipment meets IEEE Std. 4-2013 requirements?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.5.1 - RMS voltage â‰¤3% uncertainty, RMS current â‰¤5% uncertainty"
          },
          {
            "field_id": "test_equipment_calibrated",
            "label": "Test equipment current on calibration?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Equipment must have valid calibration"
          },
          {
            "field_id": "calibration_due_date",
            "label": "Calibration due date",
            "type": "DATE",
            "required": true,
            "help_text": "Must be after test date"
          },
          {
            "field_id": "test_equipment_manufacturer",
            "label": "Test equipment manufacturer",
            "type": "TEXT",
            "required": true
          },
          {
            "field_id": "test_equipment_model",
            "label": "Test equipment model",
            "type": "TEXT",
            "required": true
          },
          {
            "field_id": "test_equipment_serial",
            "label": "Test equipment serial number",
            "type": "TEXT",
            "required": true
          },
          {
            "field_id": "equipment_notes",
            "label": "Test Equipment Notes",
            "type": "TEXT_AREA",
            "required": false
          }
        ],
        "blocking_fail": true
      },
      {
        "step_key": "test_setup_cat_ab",
        "type": "SETUP",
        "title": "Test Setup for Category A or B",
        "standard_reference": "ANSI A92.2-2021 Section 5.4.3.1",
        "required": true,
        "visibility_conditions": {
          "path": "inputs.unit_category",
          "in": [
            "A",
            "B"
          ]
        },
        "fields": [
          {
            "field_id": "platform_components_bonded",
            "label": "All conductive material at platform bonded per Figure 5?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.4.3.1(1) - All conductive components electrically bonded"
          },
          {
            "field_id": "metal_liner_installed_cat_a",
            "label": "[Cat A only] Metal liner installed and bonded if non-conductive platform?",
            "type": "BOOLEAN",
            "required": false,
            "help_text": "Section 5.4.3.1(2) - Required for Category A non-conductive platforms"
          },
          {
            "field_id": "vacuum_system_verified",
            "label": "Vacuum limiting system inspected and function verified (if equipped)?",
            "type": "BOOLEAN",
            "required": false,
            "help_text": "Section 5.4.3.1(3) - Per manufacturer's manual"
          },
          {
            "field_id": "lower_electrode_inspected",
            "label": "Lower test electrode system inspected for completeness?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.4.3.1(4) - Inspect per Figure 1A"
          },
          {
            "field_id": "lower_electrode_continuity_tested",
            "label": "Lower test electrode continuity confirmed intact?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.4.3.1(4) - Must have continuity"
          },
          {
            "field_id": "hydraulic_lines_filled",
            "label": "All hydraulic lines crossing insulating section filled with oil?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.4.3.1(5) - Operate unit to fill lines"
          },
          {
            "field_id": "shunting_installed",
            "label": "Shunting jumpers installed if continuity cannot be ensured?",
            "type": "BOOLEAN",
            "required": false,
            "help_text": "Section 5.4.3.1(6) - Per Figure 1"
          },
          {
            "field_id": "chassis_system_shunted",
            "label": "Chassis insulating system shunted if equipped?",
            "type": "BOOLEAN",
            "required": false,
            "help_text": "Section 5.4.3.1(7) - Per Figure 3A"
          },
          {
            "field_id": "vehicle_grounded",
            "label": "Vehicle chassis grounded?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.4.3.1(8) - Critical safety requirement"
          },
          {
            "field_id": "meter_connected",
            "label": "Current meter receptacle connected via shielded cable to meter and ground?",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Section 5.4.3.1(9)"
          },
          {
            "field_id": "boom_positioned",
            "label": "Boom positioned per Figure 1 or Figure 4?",
            "type": "ENUM",
            "enum_ref": "boom_position_figure",
            "required": true,
            "help_text": "Section 5.4.3.1(10) - Clear from potential grounding structures"
          },
          {
            "field_id": "setup_notes",
            "label": "Test Setup Notes",
            "type": "TEXT_AREA",
            "required": false
          }
        ],
        "blocking_fail": true
      },
      {
        "step_key": "test_setup_cat_cde",
        "type": "SETUP",
        "title": "Test Setup for Category C, D, or E",
        "standard_reference": "ANSI A92.2-2021 Section 5.4.3.2",
        "required": true,
        "visibility_conditions": {
          "path": "inputs.unit_category",
          "in": [
            "C",
            "D",
            "E"
          ]
        },
        "fields": [
          {
            "field_id": "platform_components_bonded",
            "label": "All conductive material at platform bonded per Figure 5?",
