{
  "format": "AF_INSPECTION_TEMPLATE",
  "format_version": 1,
  "template": {
    "template_key": "ansi_a92_2_2021_hydraulic_system_module",
    "name": "ANSI A92.2-2021 – Hydraulic System (Module)",
    "status": "DRAFT",
    "standard": { "code": "ANSI/SAIA A92.2", "revision": "2021" },
    "intent": {
      "inspection_kind": "PERIODIC",
      "domain": "AERIAL_DEVICE",
      "tags": ["hydraulic", "hoses", "fittings", "reservoir", "filters", "pumps", "valves", "pressure"]
    },
    "policy": {
      "evidence_rules": {
        "photo_required_if_severity_at_least": "SERVICE_REQUIRED",
        "notes_required_on_fail": true,
        "block_finalize_if_required_steps_incomplete": true
      },
      "hashing": {
        "canonicalization": "JSON_CANONICAL_SORT_KEYS_UTF8_NO_WHITESPACE",
        "hash_algorithm": "SHA256"
      }
    }
  },

  "enums": {
    "severity": ["SAFE", "MINOR", "SERVICE_REQUIRED", "UNSAFE_OUT_OF_SERVICE"],
    "step_status": ["PASS", "FAIL", "NOT_PERFORMED", "NOT_APPLICABLE"],
    "inspection_context": ["PERIODIC", "POST_REPAIR", "MAJOR_REPAIR", "POST_EVENT"],
    "leak_type": ["NONE", "SEEPAGE", "DRIP", "SPRAY"],
    "fluid_condition": ["NORMAL", "DARK", "FOAMY", "BURNT_ODOR", "CONTAMINATED", "UNKNOWN"],
    "hose_condition": ["OK", "CRACKED", "ABRADED", "BULGING", "DEFORMED", "LEAKING"],
    "component_group": [
      "HOSES",
      "FITTINGS_TUBING",
      "CYLINDERS",
      "RESERVOIR",
      "FILTERS",
      "PUMPS_MOTORS",
      "VALVES",
      "PRESSURE_LIMITING_DEVICE",
      "OTHER"
    ],
    "symptom_type": [
      "LEAK",
      "CRACK",
      "ABRASION",
      "BULGE",
      "DEFORMATION",
      "LOOSE_CONNECTION",
      "CONTAMINATION",
      "DISCOLORED_FLUID",
      "MISSING_FILTER",
      "UNUSUAL_NOISE",
      "VIBRATION",
      "ERRATIC_MOVEMENT",
      "OVERHEATING",
      "STICKING_SPOOL",
      "HOUSING_CRACK",
      "OTHER"
    ],
    "action_taken": ["NONE", "REPAIRED", "REPLACED", "TIGHTENED", "CLEANED", "FLUID_CHANGED", "REMOVED_FROM_SERVICE", "DEFERRED"]
  },

  "schemas": {
    "defect_schema": {
      "defect_id_format": "UUID",
      "fields": [
        { "field_id": "title", "type": "TEXT", "required": true },
        { "field_id": "severity", "type": "ENUM", "enum_ref": "severity", "required": true },
        { "field_id": "standard_reference", "type": "TEXT", "required": false },
        { "field_id": "component_group", "type": "ENUM", "enum_ref": "component_group", "required": true },
        { "field_id": "symptoms", "type": "CHOICE_MULTI", "enum_ref": "symptom_type", "required": true },
        {
          "field_id": "location_zone",
          "type": "ENUM",
          "values": ["BASE", "TURRET", "LOWER_BOOM", "UPPER_BOOM", "JIB", "PLATFORM", "OUTRIGGERS", "CHASSIS", "OTHER"],
          "required": false
        },
        { "field_id": "location_detail", "type": "TEXT", "required": false },
        { "field_id": "inspection_context", "type": "ENUM", "enum_ref": "inspection_context", "required": false },
        { "field_id": "action_taken", "type": "ENUM", "enum_ref": "action_taken", "required": true },
        { "field_id": "notes", "type": "TEXTAREA", "required": false },
        { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
      ]
    }
  },

  "procedure": {
    "inputs": [
      { "input_id": "inspection_context", "type": "ENUM", "enum_ref": "inspection_context", "required": true },
      { "input_id": "asset_capabilities", "type": "ASSET_CAPABILITIES", "required": false }
    ],

    "steps": [
      {
        "step_key": "hydraulic_preparation",
        "type": "SETUP",
        "title": "Preparation for hydraulic system inspection",
        "standard_reference": "ANSI A92.2-2021 8.2.4(4)",
        "required": true,
        "fields": [
          { "field_id": "worksite_safe", "type": "BOOLEAN", "required": true },
          { "field_id": "device_setup_complete", "type": "BOOLEAN", "required": true },
          { "field_id": "manufacturer_manual_reviewed", "type": "BOOLEAN", "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ],
        "blocking_fail": true
      },

      {
        "step_key": "hydraulic_visual_inspection",
        "type": "DEFECT_CAPTURE",
        "title": "Visual inspection of hydraulic system components",
        "standard_reference": "ANSI A92.2-2021 8.2.3(1), 8.2.4(4)",
        "required": true,
        "defect_schema_ref": "defect_schema",
        "ui": {
          "mode": "ADD_DEFECT_ITEMS",
          "guidance": [
            "Inspect hoses for cracks, leaks, abrasions, bulges, or deformation.",
            "Inspect fittings and tubing for leaks, loose connections, or damage.",
            "Inspect cylinders for visible damage or leakage.",
            "Inspect reservoir for proper fluid level and contamination; check vent filter condition.",
            "Inspect hydraulic filters for cleanliness/foreign material."
          ]
        },
        "fields": [
          {
            "field_id": "fluid_level_ok",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Reservoir fluid level indicates proper level per manufacturer indicator."
          },
          {
            "field_id": "fluid_condition",
            "type": "ENUM",
            "enum_ref": "fluid_condition",
            "required": true
          },
          {
            "field_id": "reservoir_vent_filter_ok",
            "type": "BOOLEAN",
            "required": false,
            "help_text": "Check for missing/damaged reservoir vent filter where applicable."
          },
          {
            "field_id": "no_defects_found",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "If true, you must have zero defects recorded for this step."
          },
          { "field_id": "notes", "type": "TEXTAREA", "required": false },
          { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
        ],
        "validations": [
          {
            "validation_id": "no_defects_true_requires_zero_defects",
            "type": "CONSISTENCY",
            "rule": "IF fields.no_defects_found == true THEN defect_count == 0"
          }
        ],
        "auto_defect_on": [
          {
            "when": { "path": "fields.fluid_level_ok", "equals": false },
            "defect": {
              "title": "Hydraulic reservoir fluid level not within normal range",
              "severity": "SERVICE_REQUIRED",
              "standard_reference": "ANSI A92.2-2021 8.2.4(4) / 4.6.4"
            }
          },
          {
            "when": { "path": "fields.fluid_condition", "in": ["CONTAMINATED", "BURNT_ODOR"] },
            "defect": {
              "title": "Hydraulic fluid condition indicates contamination or overheating",
              "severity": "SERVICE_REQUIRED",
              "standard_reference": "ANSI A92.2-2021 8.2.4(4) / 4.6.5"
            }
          }
        ]
      },

      {
        "step_key": "hydraulic_functional_testing",
        "type": "FUNCTIONAL_TEST",
        "title": "Functional testing of hydraulic system",
        "standard_reference": "ANSI A92.2-2021 8.2.4(4), 4.6.1",
        "required": true,
        "fields": [
          {
            "field_id": "operated_full_range",
            "type": "BOOLEAN",
            "required": true,
            "help_text": "Operate all hydraulic functions through full range (boom movement, stabilizers, winches where applicable)."
          },
          {
            "field_id": "smooth_operation",
            "type": "BOOLEAN",
            "required": true
          },
          {
            "field_id": "anomalies_observed",
            "type": "CHOICE_MULTI",
            "choices": ["UNUSUAL_NOISE", "VIBRATION", "ERRATIC_MOVEMENT", "SLOW_RESPONSE", "OVERHEATING", "OTHER"],
            "required": false
          },
          { "field_id": "notes", "type": "TEXTAREA", "required": false },
          { "field_id": "photos", "type": "ATTACHMENTS", "required": false }
        ],
        "auto_defect_on": [
          {
            "when": { "path": "fields.smooth_operation", "equals": false },
            "defect": {
              "title": "Hydraulic system functional operation not smooth / abnormal response",
              "severity": "SERVICE_REQUIRED",
              "standard_reference": "ANSI A92.2-2021 8.2.4(4)"
            }
          }
        ]
      },

      {
        "step_key": "hydraulic_pressure_limiting_device_check",
        "type": "FUNCTIONAL_TEST",
        "title": "Verify pressure limiting device prevents exceeding maximum operating pressure",
        "standard_reference": "ANSI A92.2-2021 4.6.7",
        "required": true,
        "fields": [
          { "field_id": "pressure_limit_verified", "type": "BOOLEAN", "required": true },
          { "field_id": "adjustment_requires_tools", "type": "BOOLEAN", "required": true },
          { "field_id": "device_can_be_sealed", "type": "BOOLEAN", "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ],
        "auto_defect_on": [
          {
            "when": { "path": "fields.pressure_limit_verified", "equals": false },
            "defect": {
              "title": "Pressure limiting device did not verify / may allow overpressure",
              "severity": "UNSAFE_OUT_OF_SERVICE",
              "standard_reference": "ANSI A92.2-2021 4.6.7"
            }
          },
          {
            "when": {
              "any": [
                { "path": "fields.adjustment_requires_tools", "equals": false },
                { "path": "fields.device_can_be_sealed", "equals": false }
              ]
            },
            "defect": {
              "title": "Pressure limiting device adjustment/sealing requirements not satisfied",
              "severity": "SERVICE_REQUIRED",
              "standard_reference": "ANSI A92.2-2021 4.6.7"
            }
          }
        ]
      },

      {
        "step_key": "hydraulic_pumps_motors_inspection",
        "type": "DEFECT_CAPTURE",
        "title": "Inspect hydraulic pumps and motors",
        "standard_reference": "ANSI A92.2-2021 8.2.4(6)",
        "required": true,
        "defect_schema_ref": "defect_schema",
        "ui": {
          "mode": "ADD_DEFECT_ITEMS",
          "guidance": [
            "Inspect for loose fasteners/connections, leaks/seepage, unusual noises/vibrations, loss of operating speed, excessive heating."
          ]
        }
      },

      {
        "step_key": "hydraulic_valves_inspection",
        "type": "DEFECT_CAPTURE",
        "title": "Inspect hydraulic valves",
        "standard_reference": "ANSI A92.2-2021 8.2.4(7)",
        "required": true,
        "defect_schema_ref": "defect_schema",
        "ui": {
          "mode": "ADD_DEFECT_ITEMS",
          "guidance": [
            "Inspect for malfunction, visible cracks in valve housing, leaks, and sticking spools."
          ]
        }
      },

      {
        "step_key": "hydraulic_filters_inspection",
        "type": "DEFECT_CAPTURE",
        "title": "Inspect hydraulic filters for cleanliness and foreign material",
        "standard_reference": "ANSI A92.2-2021 8.2.4(10), 4.6.5",
        "required": true,
        "defect_schema_ref": "defect_schema",
        "ui": {
          "mode": "ADD_DEFECT_ITEMS",
          "guidance": [
            "Inspect filters for cleanliness and foreign material indicating component deterioration. Replace if contaminated or excessively worn."
          ]
        }
      },

      {
        "step_key": "hydraulic_cylinders_inspection_note",
        "type": "INSTRUCTION",
        "title": "Reference: Cylinder design/safety requirements are manufacturer/engineering governed",
        "standard_reference": "ANSI A92.2-2021 4.7 (and 4.6 requirements)",
        "required": false,
        "fields": [
          {
            "field_id": "note",
            "type": "RICH_TEXT",
            "required": false,
            "default": "Cylinder safety factors, column load limits, and locking requirements for threaded components should be verified per manufacturer criteria and qualified engineering procedures when applicable. Field inspection typically focuses on visible damage, leakage, and function."
          }
        ]
      },

      {
        "step_key": "hydraulic_post_repair_testing",
        "type": "FUNCTIONAL_TEST",
        "title": "Post-repair hydraulic system functional test",
        "standard_reference": "ANSI A92.2-2021 8.2.4(16)(c)",
        "required": false,
        "visibility_conditions": {
          "any": [
            { "path": "inspection_context", "equals": "POST_REPAIR" },
            { "path": "inspection_context", "equals": "MAJOR_REPAIR" },
            { "path": "inspection_context", "equals": "POST_EVENT" }
          ]
        },
        "fields": [
          { "field_id": "performed", "type": "BOOLEAN", "required": true },
          { "field_id": "notes", "type": "TEXTAREA", "required": false }
        ]
      },

      {
        "step_key": "hydraulic_burst_strength_reference",
        "type": "INSTRUCTION",
        "title": "Reference: Bursting safety factors (informational)",
        "standard_reference": "ANSI A92.2-2021 4.6.1",
        "required": false,
        "fields": [
          {
            "field_id": "note",
            "type": "RICH_TEXT",
            "required": false,
            "default": "Section 4.6.1 defines minimum bursting strength factors (4×, 3×, 2×) relative to maximum operating pressure. Field inspection generally verifies condition and correct components per manufacturer specifications; engineering verification applies for design compliance."
          }
        ]
      },

      {
        "step_key": "hydraulic_documentation",
        "type": "DOCUMENTATION",
        "title": "Hydraulic system inspection documentation",
        "standard_reference": "ANSI A92.2-2021 8.3.2",
        "required": true,
        "fields": [
          { "field_id": "inspection_date", "type": "DATE", "required": true },
          { "field_id": "performed_by_entity", "type": "TEXT", "required": true },
          { "field_id": "system_summary", "type": "TEXTAREA", "required": true },
          { "field_id": "findings_summary", "type": "TEXTAREA", "required": false },
          { "field_id": "actions_taken_summary", "type": "TEXTAREA", "required": false },
          { "field_id": "placard_applied", "type": "BOOLEAN", "required": true }
        ]
      }
    ]
  }
}
